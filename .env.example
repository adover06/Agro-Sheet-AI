# Google Tasks API Configuration
GOOGLE_TASKS_CREDENTIALS=config/google_credentials.json

# Google Sheets Configuration
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_CREDENTIALS=config/google_credentials.json

# Gemini Pro API (for AI-powered scheduling)
GEMINI_API_KEY=your_gemini_api_key_here

# App Configuration
SCHEDULE_START_HOUR=9
SCHEDULE_END_HOUR=24  # midnight
BLOCK_DURATION_MINUTES=30
MAX_CONTINUOUS_TASK_MINUTES=120  # 2 hours before splitting
