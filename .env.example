# Microsoft OAuth Configuration
MICROSOFT_CLIENT_ID=your_client_id_here
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_REDIRECT_URI=http://localhost:8000/callback

# Google Sheets Configuration
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_CREDENTIALS=config/google_credentials.json

# OpenAI API (for LangChain agent)
OPENAI_API_KEY=your_openai_key_here

# App Configuration
SCHEDULE_START_HOUR=9
SCHEDULE_END_HOUR=24  # midnight
BLOCK_DURATION_MINUTES=30
MAX_CONTINUOUS_TASK_MINUTES=120  # 2 hours before splitting
